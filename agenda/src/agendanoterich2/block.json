{
	"$schema": "https://schemas.wp.org/wp/trunk/block.json",
	"apiVersion": 3,
	"name": "wp4toastmasters/agendanoterich2",
	"version": "0.1.0",
	"title": "Toastmasters Agenda Note",
	"category": "toastmasters",
	"icon": "groups",
	"description": "Displays \"stage directions\" for the organization of your meetings. You can set the time allowed for an activity (5-minute break, for example).",
	"keywords": [
		"toastmasters",
		"agenda",
		"note"
	],
	"attributes": {
		"content": {
			"source": "html",
			"selector": "p"
		},
		"uid": {
			"type": "string",
			"default": ""
		},
		"time_allowed": {
			"type": "number",
			"default": 0
		}
	},
	"supports": {
		"html": true
	},
	"textdomain": "rsvpmaker-for-toastmasters",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
    "render": "file:./render.php",
	"style": "file:./style-index.css"
}
