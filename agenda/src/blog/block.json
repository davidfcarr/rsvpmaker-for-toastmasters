{
	"$schema": "https://schemas.wp.org/wp/trunk/block.json",
	"apiVersion": 3,
	"name": "wp4toastmasters/blog",
	"version": "0.1.0",
	"title": "Club News / Member Only Blog Posts",
	"category": "toastmasters",
	"icon": "groups",
	"description": "Blog posts visible only to Toastmasters members.",
	"keywords": [
		"toastmasters",
		"private",
		"blog"
	],
	"attributes": {
		"title": {
			"type": "string",
			"default": "Members Only"
		},
		"type": {
			"type": "string",
			"default": "private"
		},
		"number": {
			"type": "integer",
			"default": 10
		}
	},
	"supports": {
		"html": false
	},
	"textdomain": "rsvpmaker-for-toastmasters",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
    "render": "file:./render.php",
	"style": "file:./style-index.css"
}
